              <div className="col-md-6">
                <Form.Group className="mb-3">
                  <Form.Label className="fw-semibold">
                    Insurance Company Name
                  </Form.Label>
                  {editMode ? (
                    <LookupField
                      value={{ Id: loan.InsuranceCompanyNameId }}
                      entityName="insurancecompanies"
                      placeholder="Search Company"
                      where="s"
                      onSelect={(record) => {
                        if (!editMode) return;
                        setLoan((prev) => ({
                          ...prev,
                          InsuranceCompanyNameId: record.Id,
                          InsuranceCompanyName: record.Name,
                        }));
                      }}
                    />
                  ) : (
                    <div className="p-2 bg-light rounded">
                      {loan.InsuranceCompanyName || "—"}
                    </div>
                  )}
                </Form.Group>
              </div>

              <div className="col-md-6">
                <Form.Group className="mb-3">
                  <Form.Label className="fw-semibold">
                    Customer Bank Name
                  </Form.Label>
                  {editMode ? (
                    <LookupField
                      value={{ Id: loan.CustomerBankNameId }}
                      entityName="banks"
                      placeholder="Search Bank"
                      where="s"
                      onSelect={(record) => {
                        if (!editMode) return;
                        setLoan((prev) => ({
                          ...prev,
                          CustomerBankNameId: record.Id,
                          CustomerBankName: record.Name,
                        }));
                      }}
                    />
                  ) : (
                    <div className="p-2 bg-light rounded">
                      {loan.CustomerBankName || "—"}
                    </div>
                  )}
                </Form.Group>
              </div>

              <div className="col-md-6">
                <Form.Group className="mb-3">
                  <Form.Label className="fw-semibold">Bank IFSC</Form.Label>
                  <Form.Control
                    type="text"
                    name="BankIFSC"
                    value={loan.BankIFSC || ""}
                    readOnly={!editMode}
                    maxLength={11}
                    placeholder="ABCD0123456"
                    onChange={(e) => {
                      if (!editMode) return;
                      let val = e.target.value.toUpperCase();
                      val = val.replace(/[^A-Z0-9]/g, "");
                      updateLoanField("BankIFSC", val);
                    }}
                  />
                  {loan.BankIFSC && loan.BankIFSC.length > 0 && (
                    <small
                      style={{
                        color: IFSC_REGEX.test(loan.BankIFSC) ? "green" : "red",
                      }}
                    >
                      {IFSC_REGEX.test(loan.BankIFSC)
                        ? "Valid IFSC Code"
                        : "Invalid IFSC format (Must be ABCD0123456)"}
                    </small>
                  )}
                </Form.Group>
              </div>

              <div className="col-md-6">
                {renderField("Bank MICR", "BankMICR")}
              </div>
              <div className="col-md-6">
                {renderField("Bank Account Number", "BankAccountNumber")}
              </div>
              <div className="col-md-6">
                {renderField("Bank Branch Name", "BankBranchName")}
              </div>
              <div className="col-md-6">
                <Form.Group className="mb-3">
                  <Form.Label className="fw-semibold">Account Type</Form.Label>
                  <Form.Select
                    name="AccountType"
                    value={loan.AccountType || "Saving"}
                    disabled={!editMode}
                    onChange={(e) =>
                      updateLoanField("AccountType", e.target.value)
                    }
                  >
                    <option value="Saving">Saving</option>
                    <option value="Current">Current</option>
                    <option value="Cash Credit(CC)">Cash Credit(CC)</option>
                    <option value="Others">Others</option>
                  </Form.Select>
                </Form.Group>
              </div>
              <div className="col-md-6">
                {renderField(
                  "Customer Bank Phone Number",
                  "CustomerBankPhoneNumber"
                )}
              </div>
              <div className="col-md-6">
                {renderField("Number Of Cheques", "NumberOfCheques")}
              </div>
              <div className="col-md-6">
                {renderField("Cheque Number 1", "ChequeNumber1")}
              </div>
              <div className="col-md-6">
                {renderField("Cheque Number 2", "ChequeNumber2")}
              </div>
              <div className="col-md-6">
                {renderField("Cheque Number 3", "ChequeNumber3")}
              </div>
              <div className="col-md-6">
                {renderField("Cheque Number 4", "ChequeNumber4")}
              </div>
              <div className="col-md-6">
                {renderField("Cheque Number 5", "ChequeNumber5")}
              </div>
              <div className="col-md-6">
                {renderField("Description", "Description", {
                  as: "textarea",
                })}
              </div>
            </div>
          </section>

          {/* SYSTEM INFO */}
          <section className="mb-2">
            <h4 className="fw-bold mb-3">
              <i className="bi bi-clock-history me-2"></i>System Information
            </h4>
            <div className="row">
              <div className="col-md-6">
                <RecordLinkField
                  label="Created By"
                  id={loan.createdby_id}
                  firstName={loan.createdby_firstname}
                  lastName={loan.createdby_lastname}
                  table="user"
                />
              </div>
              <div className="col-md-6">
                <RecordLinkField
                  label="Modified By"
                  id={loan.modifiedby_id}
                  firstName={loan.modifiedby_firstname}
                  lastName={loan.modifiedby_lastname}
                  table="user"
                />
              </div>
              <div className="col-md-6">
                {renderField("Created Date", "CreatedDate", {
                  editable: false,
                })}
              </div>
              <div className="col-md-6">
                {renderField("Modified Date", "ModifiedDate", {
                  editable: false,
                })}
              </div>
            </div>
          </section>
        </Form>
        {editMode ? (
          <div className="d-flex justify-content-center gap-3 mt-4">
            <Button
              variant="secondary"
              onClick={() => {
                fetchLoan();
                resetButton();
                setEditMode(false);

                // setForm(dealer);
                setErrors({});
              }}
            >
              Cancel
            </Button>

            <Button variant="dark" onClick={handleSave} disabled={submitting}>
              {submitting ? "Saving..." : "Save"}
            </Button>
          </div>
        ) : null}
      </div>
    </div>
  );
}

// only for EMI list ids
function generateId(length = 30) {
  const timestamp = Date.now().toString(36);
  const chars =
    "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789";
  let randomPart = "";

  if (window.crypto && window.crypto.getRandomValues) {
    const randomValues = new Uint8Array(length - timestamp.length);
    window.crypto.getRandomValues(randomValues);
    randomPart = Array.from(randomValues)
      .map((num) => chars[num % chars.length])
      .join("");
  } else {
    for (let i = 0; i < length - timestamp.length; i++) {
      randomPart += chars.charAt(Math.floor(Math.random() * chars.length));
    }
  }
  const id = timestamp + randomPart;
  return id.length >= length ? id.slice(0, length) : id;
}

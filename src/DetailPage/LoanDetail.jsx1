              </div>

              <div className="col-md-6">{renderField("Bill No", "BillNo")}</div>
              <div className="col-md-6">{renderField("RC No", "RCNo")}</div>
              <div className="col-md-6">{renderField("Key No", "KeyNo")}</div>

              <div className="col-md-6">
                {renderField("Insurance Policy No", "InsurancePolicyNo")}
